<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
    <title>Details</title>
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="details-page">

            <img src="<%= item.image %>" class="details-poster" alt="<%= item.title %>">

            <div class="details-info">
                <h1>
                    <%= item.title %>
                </h1>

                <p>
                    <%= item.year %> |
                        <%= item.type %> |
                            <%= item.genre %> |
                                <%= item.duration %>
                </p>

                <p class="rating">★★★★★ <%= item.rating %>
                </p>

                <p class="details-description">
                    <%= item.description %>
                </p>

                <a class="btn" href="#">▶ Play</a>

                <form action="/add-favourite" method="POST" class="watchlist-form">
                    <input type="hidden" name="slug" value="<%= item.slug %>">
                    <button class="btn grey" type="submit">♥ Add Favourite</button>
                </form>

                <form action="/add-watching" method="POST" class="watchlist-form">
                    <input type="hidden" name="slug" value="<%= item.slug %>">
                    <button class="btn grey" type="submit">▶ Currently Watching</button>
                </form>

                <form action="/add-watched" method="POST" class="watchlist-form">
                    <input type="hidden" name="slug" value="<%= item.slug %>">
                    <button class="btn grey" type="submit">✓ Mark Watched</button>
                </form>

                <div class="info-box">
                    <p><strong>Category:</strong>
                        <%= item.type %>
                    </p>
                    <p><strong>Genre:</strong>
                        <%= item.genre %>
                    </p>
                    <p><strong>Released:</strong>
                        <%= item.year %>
                    </p>
                    <p><strong>Duration:</strong>
                        <%= item.duration %>
                    </p>
                    <p><strong>Rating:</strong>
                        <%= item.rating %>
                    </p>
                </div>
            </div>

        </div>

</body>

</html>