<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
    <title>MoodFlix</title>
</head>

<body>
    <%- include('partials/navbar') %>
        <section class="hero">
            <div class="hero-text">
                <h1>Spider-Man: No Way Home</h1>
                <p>Welcome to MoodFlix, your entertainment app for movies, TV shows and anime. Discover titles based on
                    your mood, continue watching and save your favourites.</p>
                <a class="btn" href="/details">Watch Now</a>
                <a class="btn grey" href="/watchlist">My List</a>
            </div>
        </section>

        <div class="container">

            <h2>How are you feeling today?</h2>
            <div class="mood-row">
                <button>Happy</button>
                <button>Sad</button>
                <button>Excited</button>
                <button>Romantic</button>
                <button>Scared</button>
            </div>

            <h2>Categories</h2>
            <div class="category-row">
                <a href="/movies">Movies</a>
                <a href="/tv">TV Shows</a>
                <a href="/anime">Anime</a>
            </div>

            <h2>Movies</h2>
            <div class="row">
                <% movies.forEach(movie=> { %>
                    <div class="poster-card">
                        <a href="/details">
                            <div class="poster"></div>
                        </a>
                        <h3>
                            <%= movie.title %>
                        </h3>
                        <p>
                            <%= movie.genre %> | <%= movie.year %>
                        </p>
                    </div>
                    <% }) %>
            </div>

            <h2>TV Shows</h2>
            <div class="row">
                <% tvShows.forEach(show=> { %>
                    <div class="poster-card">
                        <a href="/details">
                            <div class="poster"></div>
                        </a>
                        <h3>
                            <%= show.title %>
                        </h3>
                        <p>
                            <%= show.genre %> | <%= show.year %>
                        </p>
                    </div>
                    <% }) %>
            </div>

            <h2>Anime</h2>
            <div class="row">
                <% anime.forEach(item=> { %>
                    <div class="poster-card">
                        <a href="/details">
                            <div class="poster"></div>
                        </a>
                        <h3>
                            <%= item.title %>
                        </h3>
                        <p>
                            <%= item.genre %>
                        </p>
                    </div>
                    <% }) %>
            </div>

        </div>
</body>

</html>