<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
    <title>MoodFlix</title>
</head>

<body>
    <%- include('partials/navbar') %>
        <div class="layout">
            <h2>
                MoodFlix
            </h2>
            <p>Your World of Movies, TV Shows, and Anime!</p>
        </div>
        <div class="main">
            <input class="search" type="text" placeholder="Search for movies, TV Shows, Anime...">
            <h1>
                Welcome to MoodFlix!
            </h1>
            <p class="description">
                Step into CineVerse, a place where movies, TV shows, and anime come together in one app.
                Browse trending entertainment, discover new titles based on your mood, and keep track of
                what you love to watch.
            </p>
            <h3>
                How are you feeling today?
            </h3>
            <div class="mood-box">
                <button>Happy</button>
                <button>Sad</button>
                <button>Excited</button>
                <button>Romantic</button>
                <button>Scared</button>
            </div>

            <h3>Categories</h3>

            <div class="category-box">
                <a href="/movies">Movies</a>
                <a href="/tv">TV Shows</a>
                <a href="/anime">Anime</a>
            </div>

            <h3>Continue Watching</h3>

            <div class="card">
                <div class="poster"></div>
                <div>
                    <h3>Naruto</h3>
                    <p>Episode 22 / 220</p>
                </div>
            </div>
        </div>
</body>

</html>