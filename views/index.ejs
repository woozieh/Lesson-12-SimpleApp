<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
    <title>MoodFlix</title>
</head>

<body>
    <%- include('partials/navbar') %>

        <section class="hero">
            <div class="hero-text">
                <h1>Welcome to MoodFlix</h1>
                <p>
                    Discover movies, TV shows and anime based on your mood.
                    Save your favourites, continue watching and build your own watchlist.
                </p>

                <a class="btn" href="/details/spiderman">Watch Now</a>
                <a class="btn grey" href="/watchlist">My List</a>
            </div>
        </section>

        <div class="container">

            <h2>How are you feeling today?</h2>

            <div class="mood-row">
                <button>Happy</button>
                <button>Sad</button>
                <button>Excited</button>
                <button>Romantic</button>
                <button>Scared</button>
            </div>

            <h2>Categories</h2>

            <div class="category-row">
                <a href="/movies">Movies</a>
                <a href="/tv">TV Shows</a>
                <a href="/anime">Anime</a>
            </div>

            <h2>Continue Watching</h2>

            <div class="continue-row">

                <div class="continue-card">
                    <div class="continue-poster"></div>

                    <div class="continue-info">
                        <h3>Naruto</h3>
                        <p>Episode 22 / 220</p>

                        <div class="progress-bar">
                            <div class="progress-fill"></div>
                        </div>
                    </div>

                    <a class="play-btn" href="/details/naruto">▶</a>
                </div>

                <div class="continue-card">
                    <div class="continue-poster"></div>

                    <div class="continue-info">
                        <h3>One Piece</h3>
                        <p>Episode 455 / 1000+</p>

                        <div class="progress-bar">
                            <div class="progress-fill two"></div>
                        </div>
                    </div>

                    <a class="play-btn" href="/details/one-piece">▶</a>
                </div>

            </div>

            <h2>Movies</h2>

            <div class="row">
                <% movies.forEach(movie=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= movie.slug %>">
                            <div class="poster"></div>
                        </a>

                        <h3>
                            <%= movie.title %>
                        </h3>
                        <p>
                            <%= movie.genre %> | <%= movie.year %>
                        </p>
                    </div>
                    <% }) %>
            </div>

            <h2>TV Shows</h2>

            <div class="row">
                <% tvShows.forEach(show=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= show.slug %>">
                            <div class="poster"></div>
                        </a>

                        <h3>
                            <%= show.title %>
                        </h3>
                        <p>
                            <%= show.genre %> | <%= show.year %>
                        </p>
                    </div>
                    <% }) %>
            </div>

            <h2>Anime</h2>

            <div class="row">
                <% anime.forEach(item=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= item.slug %>">
                            <div class="poster"></div>
                        </a>

                        <h3>
                            <%= item.title %>
                        </h3>
                        <p>
                            <%= item.genre %>
                        </p>
                    </div>
                    <% }) %>
            </div>

        </div>
</body>

</html>