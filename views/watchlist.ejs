<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/styles.css">
    <title>Watchlist</title>
</head>

<body>
    <%- include('partials/navbar') %>

        <div class="container page-top">

            <h1>My Watchlist</h1>

            <div class="watch-tabs">
                <button>♥ Favourites</button>
                <button>▶ Watching</button>
                <button>✓ Watched</button>
            </div>

            <h2>Favourites</h2>

            <div class="row">
                <% favourites.forEach(item=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= item.slug %>">
                            <img src="<%= item.image %>" class="poster" alt="<%= item.title %>">
                        </a>

                        <h3>
                            <%= item.title %>
                        </h3>
                        <p>
                            <%= item.type %> | <%= item.genre %>
                        </p>
                        <p>♥ Favourite</p>
                    </div>
                    <% }) %>
            </div>

            <h2>Currently Watching</h2>

            <div class="row">
                <% watching.forEach(item=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= item.slug %>">
                            <img src="<%= item.image %>" class="poster" alt="<%= item.title %>">
                        </a>

                        <h3>
                            <%= item.title %>
                        </h3>
                        <p>
                            <%= item.type %> | <%= item.genre %>
                        </p>
                        <p>▶ Watching</p>
                    </div>
                    <% }) %>
            </div>

            <h2>Watched Recently</h2>

            <div class="row">
                <% watched.forEach(item=> { %>
                    <div class="poster-card">
                        <a href="/details/<%= item.slug %>">
                            <img src="<%= item.image %>" class="poster" alt="<%= item.title %>">
                        </a>

                        <h3>
                            <%= item.title %>
                        </h3>
                        <p>
                            <%= item.type %> | <%= item.genre %>
                        </p>
                        <p>✓ Watched</p>
                    </div>
                    <% }) %>
            </div>

            <div class="stats-box">
                <h2>Your Stats</h2>
                <p>Favourites: <%= favourites.length %>
                </p>
                <p>Watching: <%= watching.length %>
                </p>
                <p>Watched: <%= watched.length %>
                </p>
            </div>

        </div>
</body>

</html>